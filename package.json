{
  "name": "world-disasters-dashboard",
  "version": "2.0.0",
  "description": "Global emergencies dashboard",
  "private": true,
  "scripts": {
    "server": "node server.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client:dev\"",
    "build": "npm run client:build",
    "start": "node server.js",
    "lint": "eslint .",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Julien Regnault",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^15.15.0",
    "supertest": "^7.1.0"
  }
}
