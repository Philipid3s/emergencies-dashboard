{
  "emergency_dashboard_apis": {
    "weather_and_natural_disasters": [
      {
        "id": "noaa-nws-alerts",
        "source_id": "noaa_nws",
        "enabled_by_default": false,
        "name": "NOAA / National Weather Service",
        "description": "US weather alerts, warnings, watches in real-time",
        "base_url": "https://api.weather.gov",
        "endpoints": {
          "all_alerts": "https://api.weather.gov/alerts/active",
          "alerts_by_area": "https://api.weather.gov/alerts/active?area={state_code}",
          "forecast": "https://api.weather.gov/points/{lat},{lon}"
        },
        "auth_required": false,
        "api_key_required": false,
        "format": "GeoJSON",
        "coverage": "USA",
        "free": true,
        "polling_interval_minutes": 5
      },
      {
        "id": "open-meteo",
        "source_id": "open_meteo",
        "enabled_by_default": false,
        "name": "Open-Meteo",
        "description": "Free global weather forecast API, no key needed",
        "base_url": "https://api.open-meteo.com/v1",
        "endpoints": {
          "forecast": "https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current_weather=true"
        },
        "auth_required": false,
        "api_key_required": false,
        "format": "JSON",
        "coverage": "Global",
        "free": true,
        "polling_interval_minutes": 15
      },
      {
        "id": "openweathermap",
        "source_id": "openweathermap",
        "enabled_by_default": false,
        "name": "OpenWeatherMap",
        "description": "Global weather, alerts, forecasts",
        "base_url": "https://api.openweathermap.org/data/2.5",
        "endpoints": {
          "current": "https://api.openweathermap.org/data/2.5/weather?lat={lat}&lon={lon}&appid={API_KEY}",
          "alerts": "https://api.openweathermap.org/data/3.0/onecall?lat={lat}&lon={lon}&appid={API_KEY}"
        },
        "auth_required": true,
        "api_key_required": true,
        "format": "JSON",
        "coverage": "Global",
        "free": true,
        "polling_interval_minutes": 10
      }
